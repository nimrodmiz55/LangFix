{
  "manifest_version": 3,
  "name": "LangFix",
  "version": "1.0",
  "description": "Fix accidental Hebrew/English keyboard typing with Alt+C or the inline button.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
